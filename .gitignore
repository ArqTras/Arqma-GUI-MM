.DS_Store
.thumbs.db
node_modules

# Quasar core related directories
.quasar
/dist

# Cordova related directories and files
/src-cordova/node_modules
/src-cordova/platforms
/src-cordova/plugins
/src-cordova/www

# Capacitor related directories and files
/src-capacitor/www
/src-capacitor/node_modules

# BEX related directories and files
/src-bex/www
/src-bex/js/core

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.cursor/
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
Arqma.log
/bin/*
!bin/.gitkeep
package-lock.json
# .notenv
/downloads
.sdk-comm

# Optional local clone of github.com/arqma/arqma (see scripts/checkout-arqma.*)
/vendor/arqma/
# Arqma core for native wallet2 (CI clones to workspace; do not commit)
/rust/arqma-rpc-upstream/

# Prebuilt wallet FFI from GitHub Releases (build/ci/fetch-arqma-wallet-ffi-release.ps1)
.prebuilt/

# Local scratch (CI log exports, temp artifacts)
.tmp/

# Rust workspace (Tauri, core, daemon)
/rust/target
/rust/**/target
/rust/tauri-app/node_modules
/rust/tauri-app/dist
/rust/tauri-app/src-tauri/bin/*.exe
/rust/tauri-app/src-tauri/bin/arqmad
/rust/tauri-app/src-tauri/bin/arqma-wallet-rpc

# Local CI/release binaries and checksum sidecars (never commit secrets or signed builds)
build/ci/*.ipa
build/ci/*.apk
build/ci/*.aab
build/ci/SHA256SUMS-*.txt
build/ci/Arqma-Wallet-*-manifest.txt
build/ci/Arqma-Wallet-*-testflight.ipa
