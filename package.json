{
    "name": "arqma-wallet",
    "version": "3.0.7",
    "description": "Modern Electron Wallet for Arqma",
    "productName": "Arqma-Wallet",
    "repository": {
        "type": "git",
        "url": "https://github.com/arqma/arqma-wallet.git"
    },
    "cordovaId": "com.arqma.wallet",
    "author": {
        "name": "arqma",
        "email": "adminxeq@protonmail.com"
    },
    "private": true,
    "scripts": {
        "dev": "quasar dev -m electron --trace-warnings",
        "build": "quasar build -m electron",
        "build-mac-x64": "quasar build -m electron -T darwin -A x64",
        "build-mac-arm64": "quasar build -m electron -T darwin -A arm64",
        "build-windows": "quasar build -m electron -T win32",
        "build-armv7": "quasar build -m electron -T linux -A armv7l",
        "build-armv8": "quasar build -m electron -T linux -A arm64",
        "lint": "eslint --ext .js,.vue ./",
        "prepare": "husky install"
    },
    "dependencies": {
        "@metamask/sdk": "0.27.0",
        "@quasar/extras": "^1.0.0",
