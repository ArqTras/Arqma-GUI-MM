{
  "name": "arqma-wallet",
  "version": "3.0.8",
  "description": "Modern Electron Wallet for Arqma",
  "productName": "Arqma-Electron-Wallet",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArqTras/Arqma-GUI-MM.git"
  },
  "cordovaId": "com.arqma.wallet",
  "author": {
    "name": "arqma",
    "email": "biuro@ar-net.info"
  },
  "private": true,
  "scripts": {
    "dev": "quasar dev -m electron --trace-warnings",
    "build": "quasar build -m electron",
