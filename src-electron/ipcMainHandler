import { ipcMain, dialog } from "electron"
import fs from "fs"
import path from "path"
import logger from "./main-process/modules/logger"
const { objectAssignDeep } = require("object-assign-deep")
const { clipboard, nativeImage, electron } = require("electron")
const { getAppDataPath } = require("./app-data-path")

export function useIPCMainHandler (browserWindow) {
  ipcMain.handle("foo:remotes", (event, message) => {
    logger.info(`electron-main foo:remotes ${JSON.stringify(message)}`)
    const filePath = path.join(message.data_dir, message.subdirectory, message.fileName)
    const file = fs.readFileSync(filePath, { encoding: "utf-8" })
    return JSON.parse(file)
  })

  ipcMain.handle("foo:noMutate", (event, message) => {
    logger.info(`electron-main foo:noMutate ${JSON.stringify(message)}`)
    return objectAssignDeep.noMutate(message.v1, message.v2)
  })

  ipcMain.handle("foo:join", (event, message) => {
    logger.info(`electron-main foo:join ${JSON.stringify(message)}`)
    return path.join(message.data_dir, message.subdirectory, message.fileName)
  })

  ipcMain.handle("foo:writeText", (event, message) => {
    const a = clipboard.writeText(message)
    return a
  })

  ipcMain.handle("foo:writeImage", (event, message) => {
    const a = clipboard.writeImage(message)
    return a
  })

  ipcMain.handle("foo:createFromDataURL", (event, data) => {
    logger.info(`electron-main foo:createFromDataURL ${JSON.stringify(data)}`)
    const a = nativeImage.createFromDataURL(data)
    return a
  })

  ipcMain.handle("foo:error", (event, message) => {
    logger.error(`${message.module} ${message.method} ${message.message}`)
  })

  ipcMain.handle("foo:info", (event, message) => {
    logger.info(`${message.module} ${message.method} ${message.message}`)
  })

  ipcMain.handle("foo:openDirectory", async (event, path) => {
    logger.info("electron-main foo:openDirectory")
    return await dialog.showOpenDialog(browserWindow, { properties: ["openDirectory"], defaultPath: path })
  })

  ipcMain.handle("foo:saveLoggingLevelToEnvironmentFile", async (event, value) => {
    try {
      logger.info("electron-main foo:saveLoggingLevelToEnvironmentFile")
      let environmentFile = ""
      if (process.env.NODE_ENV === "development") {
        environmentFile = path.join(__resourceDirectory, ".env")
      } else {
        const environmentDirectory = getAppDataPath("Arqma-Electron-Wallet")
        environmentFile = path.join(environmentDirectory, ".env")
      }

      const file = await fs.readFileSync(environmentFile, { encoding: "utf-8", flag: "a+" })
      const lines = file.split("\n")
      if (lines[0] === "") {
        lines[0] = `LOG_LEVEL=${value}`
        lines.push(`CUSTOM_VERSION=${process.env.CUSTOM_VERSION}`)
      } else {
        lines.some((line, index) => {
          if (line.startsWith("LOG_LEVEL")) {
            lines[index] = `LOG_LEVEL=${value}`
            return true
          }
          if (line.startsWith("CUSTOM_VERSION") || line.startsWith("VERSION")) {
            lines[index] = `CUSTOM_VERSION=${process.env.CUSTOM_VERSION}`
            return true
          }
          return false
        })
      }
      fs.writeFileSync(
        environmentFile,
        lines.join("\n")
      )
    } catch (error) {
      logger.error(`electron-main foo:saveLoggingLevelToEnvironmentFile ${error.stack || error}`)
    }
  })
}
